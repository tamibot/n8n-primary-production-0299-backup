          "jsCode": "const item = items[0].json;\n\nif (item.next_url) {\n  // Forma moderna de guardar datos globales\n  $getWorkflowStaticData('global').nextUrl = item.next_url;\n  console.log(`Parte ${item.partNumber}/${item.totalParts} subida`);\n}\n\nif (item.isLastPart) {\n  item.message = '✅ Archivo cargado exitosamente';\n  console.log(`\\n✅ CARGA COMPLETA: ${item.name || item.sanitized_name}`);\n  \n  // Forma moderna de limpiar datos globales\n  delete $getWorkflowStaticData('global').nextUrl;\n}\n\nreturn [{ json: item }];"
