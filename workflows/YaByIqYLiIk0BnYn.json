        "id": "3970249a-055d-496e-aa2f-2dd7728b8135",
        "name": "Merge2"
      },
      {
        "parameters": {
          "jsCode": "const sessionData = items[0].json;\nconst fileBuffer = Buffer.from(sessionData.fileBuffer, 'base64');\nconst maxPartSize = sessionData.max_part_size || 524288;\nconst totalSize = fileBuffer.length;\nconst numParts = Math.ceil(totalSize / maxPartSize);\n\nconsole.log(`Archivo dividido en ${numParts} partes.`);\n\nconst parts = [];\nfor (let i = 0; i < numParts; i++) {\n  const start = i * maxPartSize;\n  const end = Math.min(start + maxPartSize, totalSize);\n  const partBuffer = fileBuffer.slice(start, end);\n  \n  // Convertimos el trozo a un objeto binario de n8n\n  const binaryData = await this.helpers.prepareBinaryData(partBuffer, `part_${i + 1}.bin`);\n\n  parts.push({\n    json: {\n      partNumber: i + 1,\n      totalParts: numParts,\n      partSize: partBuffer.length,\n      isLastPart: (i === numParts - 1),\n      sessionId: sessionData.session_id,\n      uploadUrl: i === 0 ? sessionData.upload_url : null,\n      fileName: sessionData.fileName,\n      fileSize: sessionData.fileSize,\n      driveLetter: sessionData.driveLetter\n    },\n    // Adjuntamos los datos binarios directamente\n    binary: {\n      data: binaryData\n    }\n  });\n}\n\nreturn parts;"
        },
