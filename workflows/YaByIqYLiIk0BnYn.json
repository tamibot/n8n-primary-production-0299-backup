          "url": "=https://drive-{{ $json.driveLetter }}.kommo.com/v1.0/sessions",
          "authentication": "genericCredentialType",
          "genericAuthType": "oAuth2Api",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Content-Type",
