        "jsCode": "const currentPart = items[0].json;\n\nif (currentPart.partNumber > 1) {\n  // Forma moderna de leer datos globales\n  currentPart.uploadUrl = $getWorkflowStaticData('global').nextUrl;\n  console.log(`Parte ${currentPart.partNumber}/${currentPart.totalParts}: Usando URL de continuación`);\n}\n\nif (!currentPart.uploadUrl) {\n  throw new Error(`No se encontró URL de carga para la parte ${currentPart.partNumber}`);\n}\n\nreturn items; // Pasamos el item completo (json y binary)"
